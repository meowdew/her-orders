<view class="page">
  <view class="hero">
    <text class="eyebrow">订单工作台</text>
    <text class="title">Her Orders</text>
    <text class="subtitle">从这里开始管理订单、客户和交付状态。</text>
  </view>

  <view class="summary">
    <view class="summary-item">
      <text class="summary-value">0</text>
      <text class="summary-label">今日订单</text>
    </view>
    <view class="summary-item">
      <text class="summary-value">0</text>
      <text class="summary-label">待确认</text>
    </view>
    <view class="summary-item">
      <text class="summary-value">0</text>
      <text class="summary-label">已完成</text>
    </view>
  </view>

  <button class="primary-action" bindtap="handleCreateOrder">新建订单</button>
</view>
