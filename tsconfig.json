{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "types": [
      "miniprogram-api-typings"
    ]
  },
  "include": [
    "miniprogram/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "miniprogram/miniprogram_npm"
  ]
}
